# Compiled binaries
/bin/
/agent-builder

# Go test/coverage output
*.out
coverage.*

# Per-task worktrees (created by scripts/start-task.sh under concurrent sessions)
.claude/worktrees/

# Per-session lock files (used by session-lock.py to detect concurrent sessions)
.claude/sessions/

# Secrets / local env
.env

# Editor
.idea/
.vscode/

# L6 probe evidence — operator-generated, regenerated each run (task 044)
docs/plans/l6-evidence.txt

# Operator-provisioned Gate toolchain binaries (host-specific, large; never commit) — runbook 1b
containment/execution-box/gate-tools/*
!containment/execution-box/gate-tools/.gitkeep

# execution-box --probe worktree write-test artifact (regenerated each real probe run)
.execution-box-probe/
